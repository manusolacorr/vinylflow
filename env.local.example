# Discogs OAuth (get at discogs.com/settings/developers → Register your application)
DISCOGS_CONSUMER_KEY=your_consumer_key_here
DISCOGS_CONSUMER_SECRET=your_consumer_secret_here

# Your app URL (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Session secret — min 32 chars random string
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_with_long_random_secret_min_32_chars
